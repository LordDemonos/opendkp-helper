{
  "name": "opendkp-helper",
  "version": "1.2.8",
  "private": true,
  "description": "OpenDKP Helper extension - test runner",
  "scripts": {
    "build:chrome": "node scripts/build-chrome.js",
    "build:firefox": "node scripts/build-firefox.js",
    "validate:manifest": "node scripts/validate-manifest.js",
    "lint:webext": "web-ext lint --source-dir . --ignore-files \"build/**\" \"node_modules/**\" \"dist/**\"",
